# API base URL — set per environment (no default in code). Use Docker build-arg in prod.
# For prod CORS: the API server must allow your frontend origin (e.g. https://prod.amulai.in) in Access-Control-Allow-Origin.
VITE_API_BASE_URL=https://api.prod.amulai.in
VITE_API_KEY=token-goes-here

# Dev only: proxy target so the dev server proxies /api to the real API (avoids CORS).
# With this set, use VITE_API_BASE_URL= or VITE_API_BASE_URL=/api so requests go to same origin.
# VITE_DEV_PROXY_TARGET=https://api.prod.amulai.in

# Optional: telemetry service base URL or path (default: /observability-service)
# VITE_TELEMETRY_URL=/observability-service
MODE=development
VITE_TTS_PROVIDER=bhashini
VITE_TRANSCRIPTION_PROVIDER=bhashini
